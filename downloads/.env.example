# Copy this file to .env and fill in real values. .env is git-ignored —
# never commit real secrets.

PORT=3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# ---------- PingPong AI Core ----------
# Which provider file under ai/providers/ to use. To swap providers later,
# add a new ai/providers/<name>-provider.js and change this value — no other
# code changes needed.
AI_PROVIDER=gemini

# Get this from Google AI Studio. Keep it ONLY in this .env file — never put
# it in frontend/mobile/Flutter code, the APK, or a GitHub repo.
GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.0-flash

# Optional tuning (defaults shown):
# AI_MAX_HISTORY_TURNS=12
# AI_MONITOR_INTERVAL_MS=30000
